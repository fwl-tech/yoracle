# Clerk (disabled — replaced with simple email/password auth, see AUTH_SESSION_SECRET below)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/apps/yoracle/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/apps/yoracle/sign-up
# NEXT_PUBLIC_CLERK_PROXY_URL=/apps/yoracle/__clerk
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/digest
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Simple email/password auth session signing key (32+ random chars, e.g. `openssl rand -hex 32`)
AUTH_SESSION_SECRET=change-me-to-a-long-random-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Connector credential encryption (32+ chars)
CONNECTOR_ENCRYPTION_KEY=change-me-to-a-32-char-secret!!

# Optional: email digest (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Yoracle <insights@yoracle.app>

# Optional: Slack bot
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_BOT_USER_ID=

# Optional: cron job auth
CRON_SECRET=

# App URLs (set automatically in next.config.js for base path)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
